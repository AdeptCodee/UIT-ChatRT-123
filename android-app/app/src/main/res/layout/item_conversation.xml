<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:id="@+id/layoutConvoItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:orientation="horizontal">

        <!-- VÙNG CHỨA AVATAR LINH HOẠT -->
        <FrameLayout
            android:layout_width="50dp"
            android:layout_height="50dp">

            <!-- 1. Hiển thị ảnh thật -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivConvoAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- 2. Hiển thị chữ cái mặc định (Dùng khi ko có ảnh) -->
            <TextView
                android:id="@+id/tvDefaultAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/status_bg"
                android:backgroundTint="@color/primary_purple"
                android:gravity="center"
                android:text="U"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="visible" />

            <!-- 3. Hiển thị nhóm Avatar (Cho Group Chat) -->
            <LinearLayout
                android:id="@+id/layoutGroupAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone" />

            <!-- DẤU CHẤM TRẠNG THÁI -->
            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="2dp"
                android:background="@drawable/ic_status_dot"
                android:visibility="gone" />

            <!-- BADGE SỐ TIN NHẮN CHƯA ĐỌC -->
            <TextView
                android:id="@+id/tvUnreadCount"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:background="@drawable/status_bg"
                android:backgroundTint="#D946EF"
                android:gravity="center"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvConvoName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên người dùng"
                android:textColor="#111827"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLastMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Nội dung tin nhắn cuối cùng..."
                android:textColor="#6B7280"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_more"
            app:tint="#D1D5DB" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
