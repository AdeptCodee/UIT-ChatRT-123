<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile &amp; Settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginBottom="16dp"/>

        <!-- Banner Tím Gradient -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/profile_banner_gradient">

                <!-- Avatar Container -->
                <RelativeLayout
                    android:id="@+id/avatarContainer"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp">

                    <!-- Avatar mặc định (Chữ cái đầu) -->
                    <TextView
                        android:id="@+id/tvDefaultAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/circle_purple"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="#FFFFFF"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                    <!-- Avatar ảnh thực tế -->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:civ_border_width="3dp"
                        app:civ_border_color="#FFFFFF"
                        android:visibility="visible"/>

                    <!-- Nút đổi Avatar -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnChangeAvatar"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        app:fabCustomSize="32dp"
                        app:srcCompat="@android:drawable/ic_menu_camera"
                        app:backgroundTint="#FFFFFF"
                        app:tint="#7C3AED"
                        app:elevation="4dp"
                        android:contentDescription="Change Avatar" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/avatarContainer"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDisplayNameHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvBioHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&gt;&gt;&gt; Dòng giới thiệu mặc định!! &lt;&lt;&lt;"
                        android:textColor="#E5E7EB"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Status Online -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="16dp"
                    android:background="@drawable/status_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="● Online"
                    android:textColor="#10B981"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tabs giả lập -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:background="@drawable/edit_text_bg"
            android:padding="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tài Khoản" android:gravity="center" android:padding="8dp" android:textSize="12sp" android:textColor="#6B7280"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cấu Hình" android:gravity="center" android:padding="8dp" android:textSize="12sp" android:textColor="#6B7280"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bảo Mật" android:gravity="center" android:padding="8dp" android:textSize="12sp" android:textColor="#6B7280"/>
        </LinearLayout>

        <!-- Form thông tin -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="♡ Thông tin cá nhân"
                    android:textStyle="bold"
                    android:textColor="#7C3AED"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cập nhật chi tiết cá nhân và thông tin hồ sơ của bạn"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="4dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="3"
                    android:layout_marginTop="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên hiển thị" android:textSize="12sp" android:textStyle="bold"/>
                        <EditText android:id="@+id/etProfileDisplayName" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="13sp" android:layout_marginTop="4dp" android:hint="Display Name"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên người dùng" android:textSize="12sp" android:textStyle="bold"/>
                        <EditText android:id="@+id/etUsername" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="13sp" android:layout_marginTop="4dp" android:enabled="false"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginTop="12dp" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email" android:textSize="12sp" android:textStyle="bold"/>
                        <EditText android:id="@+id/etProfileEmail" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="13sp" android:layout_marginTop="4dp" android:enabled="false"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginTop="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số điện thoại" android:textSize="12sp" android:textStyle="bold"/>
                        <EditText android:id="@+id/etPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="13sp" android:layout_marginTop="4dp" android:hint="Phone number"/>
                    </LinearLayout>

                </GridLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giới thiệu" android:layout_marginTop="12dp" android:textSize="12sp" android:textStyle="bold"/>
                <EditText android:id="@+id/etBio" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/edit_text_bg" android:padding="10dp" android:textSize="13sp" android:layout_marginTop="4dp" android:minLines="3" android:gravity="top" android:hint="Write something about you..."/>

                <Button
                    android:id="@+id/btnUpdateProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lưu thay đổi"
                    android:backgroundTint="#D946EF"
                    android:layout_marginTop="20dp"
                    android:textAllCaps="false"
                    android:paddingHorizontal="24dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
